    {
      "parameters": {
        "jsCode": "// 1. Get all items from the Google Sheets Trigger and the previous node\nconst sheetItems = $('Google Sheets Trigger').all();\nconst copiedDocs = $input.all();\n\n// 2. Map through every record to process them all\nreturn sheetItems.map((sheetItem, index) => {\n  const sheetInput = sheetItem.json;\n  \n  // Find the matching copied document for this row (fallback to the first one if counts don't match)\n  const copiedDoc = (copiedDocs[index] || copiedDocs[0]).json;\n\n  const requests = [];\n\n  // 3. Loop through every single column in the current row automatically\n  for (const [key, value] of Object.entries(sheetInput)) {\n    // Converts a header like \"Seller Name\" into \"{{SELLER_NAME}}\"\n    const placeholder = `{{${key.replace(/\\s+/g, '_').toUpperCase()}}}`;\n    \n    requests.push({\n      replaceAllText: {\n        containsText: {\n          text: placeholder,\n          matchCase: true\n        },\n        replaceText: (value !== null && value !== undefined) ? String(value) : ''\n      }\n    });\n  }\n\n  // 4. Return the structured payload for this specific record\n  return {\n    json: {\n      ...sheetInput,\n      documentId: copiedDoc.id,\n      requests\n    }\n  };\n});"
      },

    {
      "parameters": {
        "jsCode": "function extractText(value) {\n  if (typeof value === 'string') return value;\n  if (Array.isArray(value)) return value.map(extractText).join('');\n  if (value && typeof value === 'object') {\n    return Object.values(value).map(extractText).join('');\n  }\n  return '';\n}\n\n// 1. Grab all incoming records and all source node records\nconst allDocuments = $input.all();\nconst allSources = $('Read Copied Document').all();\n\n// 2. Map over every incoming item to process them all\nreturn allDocuments.map((docItem, index) => {\n  const documentResponse = docItem.json;\n  \n  // Find the matching source record by index (fallback to the first one if counts differ)\n  const source = (allSources[index] || allSources[0]).json;\n  \n  // Extract text and find placeholders for this specific document\n  const text = extractText(documentResponse);\n  const remaining = [...new Set(text.match(/\\{\\{[A-Z0-9_]+\\}\\}/g) || [])];\n\n  // 3. Return the structured payload for this specific item\n  return {\n    json: {\n      copiedDocumentId: source.copiedDocumentId,\n      copiedDocumentName: source.copiedDocumentName,\n      copiedDocumentUrl: source.copiedDocumentUrl,\n      saleId: source.saleId,\n      verificationPassed: remaining.length === 0,\n      remainingPlaceholders: remaining,\n      pdfFileName: `${source.title || source.copiedDocumentName}.pdf` \n    }\n  };\n});"
      },

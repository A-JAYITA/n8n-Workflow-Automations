    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nconst positive = [];\nconst neutral = [];\nconst negative = [];\n\nfor (const row of rows) {\n  const feedback = row.json.feedback;\n  const sentiment = String(row.json.sentiment || '').toLowerCase().trim();\n\n  if (sentiment === 'positive') {\n    positive.push(feedback);\n  } else if (sentiment === 'neutral') {\n    neutral.push(feedback);\n  } else if (sentiment === 'negative') {\n    negative.push(feedback);\n  }\n}\n\nreturn [\n  {\n    json: {\n      positive_count: positive.length,\n      positive_feedback: positive,\n      neutral_count: neutral.length,\n      neutral_feedback: neutral,\n      negative_count: negative.length,\n      negative_feedback: negative,\n      aggregated_at: new Date().toISOString()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1216,
        -128
      ],
      "id": "38f92b3d-ec04-4090-b14a-2621fbae7a6e",
